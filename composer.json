{
    "name": "jdz/htmlrenderer",
    "type": "library",
    "description": "HTML Renderer",
    "keywords": [
        "JDZ",
        "utilities",
        "html",
        "twig",
        "template"
    ],
    "homepage": "https://jdz.joffreydemetz.com/htmlrenderer",
    "license": "MIT",
    "authors": [
        {
            "name": "Joffrey Demetz",
            "email": "joffrey.demetz@gmail.com",
            "homepage": "https://joffreydemetz.com",
            "role": "Lead"
        }
    ],
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "JDZ\\Renderer\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JDZ\\Renderer\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "phpunit --colors=always --testdox",
        "test-coverage": "phpunit --coverage-html coverage"
    }
}
